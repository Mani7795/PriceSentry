# ─── Postgres ──────────────────────────────────────────────────────────
POSTGRES_USER=pricesentry
POSTGRES_PASSWORD=pricesentry_dev
POSTGRES_DB=pricesentry

# ─── Scraper ───────────────────────────────────────────────────────────
# Default target: a public scraping sandbox. SAFE to run.
SCRAPE_TARGET=demo

# Set to 1 to enable the Chewy live target. Off by default for ToS reasons.
# DO NOT enable without reviewing robots.txt and rate-limiting.
CHEWY_LIVE=0

# Politeness controls (apply to all live targets)
SCRAPE_REQUEST_DELAY_SECONDS=8
SCRAPE_USER_AGENT="PriceSentry-portfolio (+https://github.com/<you>; <you>@example.com)"

# ─── LLM provider for RAG ──────────────────────────────────────────────
# Pick ONE:
#   anthropic — uses Claude Haiku via the Anthropic API
#   bedrock   — uses Claude Haiku via AWS Bedrock (Phase 3)
#   ollama    — uses a local model via Ollama (zero-cost; needs Ollama running)
LLM_PROVIDER=ollama

# If LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-PUT-YOURS-HERE

# If LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# If LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=64

# ─── RAG ───────────────────────────────────────────────────────────────
RAG_TOP_K=20
RAG_RERANK_TOP_N=5

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
