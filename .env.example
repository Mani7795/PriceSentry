# ─── Postgres ──────────────────────────────────────────────────────────
POSTGRES_USER=pricesentry
POSTGRES_PASSWORD=pricesentry_dev
POSTGRES_DB=pricesentry

# ─── App ───────────────────────────────────────────────────────────────
APP_NAME=PriceSentry
APP_ENV=dev
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ─── CORS (comma-separated origins allowed to call the API) ────────────
# In dev, the Next.js frontend is at http://localhost:3000.
CORS_ORIGINS=http://localhost:3000

# ─── Auth ──────────────────────────────────────────────────────────────
# Generate a strong secret for prod: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ─── Scraper ───────────────────────────────────────────────────────────
SCRAPE_TARGET=demo
CHEWY_LIVE=0
SCRAPE_REQUEST_DELAY_SECONDS=8
SCRAPE_USER_AGENT="PriceSentry-portfolio (+https://github.com/<you>; <you>@example.com)"

# ─── LLM provider for RAG ──────────────────────────────────────────────
# Pick ONE:
#   ollama    — local model (default for dev)
#   anthropic — Claude via Anthropic API
#   openai    — OpenAI API
#   bedrock   — Claude via AWS Bedrock (Phase 3)
LLM_PROVIDER=ollama

# Anthropic
ANTHROPIC_API_KEY=sk-ant-PUT-YOURS-HERE
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI
OPENAI_API_KEY=sk-PUT-YOURS-HERE
OPENAI_MODEL=gpt-4o-mini

# Bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Ollama (recommended for $0-cost dev)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# ─── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=64

# ─── RAG ───────────────────────────────────────────────────────────────
RAG_TOP_K=10
RAG_RERANK_TOP_N=3
RAG_HISTORY_WINDOW=6
